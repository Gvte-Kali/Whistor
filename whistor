# =============================================================================
# COMMAND: start
# =============================================================================
# Bring up all containers defined in docker-compose.yml in detached mode.
# After starting, immediately print the stack status.
# =============================================================================
cmd_start() {
  info "Starting the whistor stack..."
  compose up -d
  ok "Stack started"
  cmd_status
}

# =============================================================================
# COMMAND: stop
# =============================================================================
# Stop and remove all containers defined in docker-compose.yml.
# Docker volumes (data, tor keys) are NOT removed ‚ÄĒ data is preserved.
# =============================================================================
cmd_stop() {
  info "Stopping the whistor stack..."
  compose down
  ok "Stack stopped"
}

# =============================================================================
# COMMAND: restart
# =============================================================================
# Restart all running containers without recreating them.
# Useful after editing configuration files.
# =============================================================================
cmd_restart() {
  info "Restarting the whistor stack..."
  compose restart
  ok "Stack restarted"
  cmd_status
}

# =============================================================================
# COMMAND: status
# =============================================================================
# Show the current state of all containers and the .onion address.
# =============================================================================
cmd_status() {
  section "Stack status"
  compose ps
  echo ""

  local onion
  onion=$(get_onion)
  if [[ "$onion" != "unavailable" ]]; then
    ok "Homeserver URL: ${BOLD}http://${onion}:8448${NC}"
  else
    warn ".onion address not available (is Tor still bootstrapping?)"
  fi
}

# =============================================================================
# COMMAND: logs
# =============================================================================
# Follow the combined log output of all containers in real time.
# Any extra arguments are passed through to docker compose logs
# (e.g. `whistor logs synapse-server` to filter by service).
# =============================================================================
cmd_logs() {
  # Pass all remaining arguments through to docker compose logs.
  # -f means "follow" ‚ÄĒ stream new log lines as they appear.
  compose logs -f "${@}"
}

# =============================================================================
# COMMAND: update
# =============================================================================
# Pull the latest versions of all Docker images used by the stack,
# then recreate containers to use the new images.
# Data volumes are not affected.
# =============================================================================
cmd_update() {
  info "Pulling latest Docker images..."
  compose pull

  info "Recreating containers with updated images..."
  compose up -d

  ok "Update complete"
}

# =============================================================================
# COMMAND: onion
# =============================================================================
# Print the .onion address and the full homeserver URL in a readable format.
# This is the URL users need to enter in their Matrix client.
# =============================================================================
cmd_onion() {
  local onion
  onion=$(get_onion)

  if [[ "$onion" == "unavailable" ]]; then
    die ".onion address is not available. Is the stack running? (whistor start)"
  fi

  echo ""
  echo -e "  ${BOLD}.onion address:${NC}"
  echo -e "  ${CYAN}${onion}${NC}"
  echo ""
  echo -e "  ${BOLD}Matrix homeserver URL:${NC}"
  echo -e "  ${CYAN}http://${onion}:8448${NC}"
  echo ""
  echo -e "  ${DIM}Enter this URL in your Matrix client's homeserver field.${NC}"
  echo ""
}

# =============================================================================
# COMMAND: config
# =============================================================================
# Print the contents of whistor.config ‚ÄĒ the file generated by install.sh
# that contains all client setup instructions and server parameters.
# =============================================================================
cmd_config() {
  local config_file="${INSTALL_DIR}/whistor.config"
  if [[ -f "$config_file" ]]; then
    cat "$config_file"
  else
    die "whistor.config not found in ${INSTALL_DIR}. Re-run install.sh to generate it."
  fi
}

# =============================================================================
# COMMAND: backup
# =============================================================================
# Create a compressed archive of both Docker volumes:
#   - whistor_tor-data     : Tor hidden service keys (your .onion identity)
#   - whistor_synapse-data : Synapse database, media store, signing key
#
# The archive is saved to $INSTALL_DIR/backups/ with a timestamp in the name.
# We use a temporary Alpine container to access the volumes from the host.
# =============================================================================
cmd_backup() {
  local backup_dir="${INSTALL_DIR}/backups"
  local timestamp
  timestamp=$(date '+%Y%m%d-%H%M%S')
  local backup_file="${backup_dir}/whistor-backup-${timestamp}.tar.gz"

  # Create the backup directory if it does not exist.
  mkdir -p "$backup_dir"

  info "Backing up Tor keys and Synapse data..."

  # Run a temporary Alpine container that mounts both volumes read-only
  # and writes the archive to the backup directory on the host.
  docker run --rm \
    -v whistor_tor-data:/tor:ro \
    -v whistor_synapse-data:/synapse:ro \
    -v "${backup_dir}:/backup" \
    alpine tar czf "/backup/whistor-backup-${timestamp}.tar.gz" /tor /synapse

  ok "Backup saved: ${backup_file}"
  info "Size: $(du -sh "$backup_file" | cut -f1)"
  warn "Store this file in a safe place. It contains your .onion private key."
}

# =============================================================================
# COMMAND GROUP: user
# =============================================================================
# Dispatches to the appropriate user management sub-command.
# =============================================================================
# =============================================================================
# COMMAND: user <username>
# =============================================================================
# Display connection information for a given user.
# =============================================================================
cmd_user_info() {
  local username="${1:-}"
  [[ -z "$username" ]] && die "Usage: whistor user conf <username>"

  check_running

  local onion
  onion=$(get_onion)
  [[ "$onion" == "unavailable" ]] && die ".onion address not available. Is the stack running?"

  # Verify the user exists in the database
  local exists
  exists=$(docker exec "$SYNAPSE_CONTAINER" \
    python3 -c "
import sqlite3
con = sqlite3.connect('/data/homeserver.db')
row = con.execute(\"SELECT name FROM users WHERE name LIKE '@${username}:%'\").fetchone()
print('yes' if row else 'no')
con.close()
" 2>/dev/null) || die "Could not query the database."
  [[ "$exists" != "yes" ]] && die "User '@${username}' not found."

  local matrix_id="@${username}:${onion}"
  local server_url="http://${onion}:8448"

  echo ""
  echo -e "  ${BOLD}Connection info for ${CYAN}${username}${NC}"
  echo ""
  echo -e "  ${BOLD}Matrix ID        :${NC} ${CYAN}${matrix_id}${NC}"
  echo -e "  ${BOLD}Homeserver URL   :${NC} ${CYAN}${server_url}${NC}"
  echo ""
  echo -e "  ${DIM}In Element: Sign in ‚Üí Edit homeserver ‚Üí enter the URL above${NC}"
  echo ""
}

# =============================================================================
# COMMAND: user qr <username> <password>
# =============================================================================
# Print a QR code containing the full credentials as plain text.
# When scanned, the phone displays a note with Matrix ID, password, and URL.
# Password cannot be recovered from the database (bcrypt) ‚ÄĒ must be provided.
# Requires qrencode (installed by install.sh).
# =============================================================================
cmd_user_qr() {
  local username="${1:-}"
  [[ -z "$username" ]] && die "Usage: whistor user qr <username>"

  check_running

  local onion
  onion=$(get_onion)
  [[ "$onion" == "unavailable" ]] && die ".onion address not available. Is the stack running?"

  # Verify user exists
  local exists
  exists=$(docker exec "$SYNAPSE_CONTAINER" \
    python3 -c "
import sqlite3
con = sqlite3.connect('/data/homeserver.db')
row = con.execute(\"SELECT name FROM users WHERE name LIKE '@${username}:%'\").fetchone()
print('yes' if row else 'no')
con.close()
" 2>/dev/null) || die "Could not query the database."
  [[ "$exists" != "yes" ]] && die "User '@${username}' not found."

  local matrix_id="@${username}:${onion}"
  local server_url="http://${onion}:8448"

  # Prompt for password ‚ÄĒ press Enter to leave blank
  local password=""
  echo -n "Password for @${username} (Enter to skip): "
  read -rs password
  echo ""

  local qr_data="Server URL : ${server_url}
Matrix ID  : ${matrix_id}
Password   : ${password}"

  echo ""
  echo -e "  ${BOLD}QR code for ${CYAN}${username}${NC}"
  echo -e "  ${DIM}Scan with any phone camera ‚ÄĒ saves as a note with full credentials${NC}"
  echo ""

  if command -v qrencode &>/dev/null; then
    qrencode -t ansiutf8 -m 2 "$qr_data"
  elif python3 -c "import qrcode" &>/dev/null 2>&1; then
    python3 -c "
import qrcode
qr = qrcode.QRCode(border=2)
qr.add_data('''${qr_data}''')
qr.make(fit=True)
qr.print_ascii(invert=True)
"
  else
    die "qrencode not found. Run: sudo apt install qrencode"
  fi

  echo ""
  echo -e "  ${BOLD}Matrix ID      :${NC} ${CYAN}${matrix_id}${NC}"
  echo -e "  ${BOLD}Homeserver URL :${NC} ${CYAN}${server_url}${NC}"
  echo ""
}

cmd_user() {
  local subcmd="${1:-}"
  shift || true   # Remove the sub-command from the argument list.

  case "$subcmd" in
    add)    cmd_user_add    "$@" ;;
    admin)  cmd_user_admin  "$@" ;;
    list)   cmd_user_list        ;;
    delete) cmd_user_delete "$@" ;;
    passwd) cmd_user_passwd "$@" ;;
    conf)   cmd_user_info   "$@" ;;
    qr)     cmd_user_qr     "$@" ;;
    *)
      echo -e "Available sub-commands: ${CYAN}add${NC}  ${CYAN}admin${NC}  ${CYAN}conf${NC}  ${CYAN}qr${NC}  ${CYAN}list${NC}  ${CYAN}delete${NC}  ${CYAN}passwd${NC}"
      exit 1
      ;;
  esac
}

# =============================================================================
# COMMAND: user add
# =============================================================================
# Create a new regular (non-admin) Matrix user account.
#
# If no password is provided as an argument, the script prompts for one
# interactively with confirmation, hiding the input with `read -rs`.
#
# A minimum password length of 8 characters is enforced.
# =============================================================================
cmd_user_add() {
  check_running

  local username="${1:-}"
  local password="${2:-}"

  [[ -z "$username" ]] && die "Usage: whistor user add <username> [password]"

  # If no password was passed as an argument, prompt for one interactively.
  if [[ -z "$password" ]]; then
    echo -n "Password for @${username}: "
    read -rs password      # -r: no backslash escapes, -s: silent (no echo)
    echo ""
    echo -n "Confirm password: "
    read -rs password_confirm
    echo ""
    [[ "$password" != "$password_confirm" ]] && die "Passwords do not match."
  fi

  # Enforce a minimum password length.
  [[ ${#password} -lt 8 ]] && die "Password too short (minimum 8 characters)."

  info "Creating user @${username}..."
  register_user "$username" "$password" "--no-admin"
  ok "User created: ${BOLD}@${username}:$(get_onion)${NC}  ‚Üí  http://$(get_onion):8448${NC}"
}

# =============================================================================
# COMMAND: user admin
# =============================================================================
# Create a new admin Matrix user account.
# Admins can access the Synapse admin API and manage the server.
# Otherwise identical to `user add`.
# =============================================================================
cmd_user_admin() {
  check_running

  local username="${1:-}"
  local password="${2:-}"

  [[ -z "$username" ]] && die "Usage: whistor user admin <username> [password]"

  # Prompt for password interactively if not provided as an argument.
  if [[ -z "$password" ]]; then
    echo -n "Password for @${username} (admin): "
    read -rs password
    echo ""
    echo -n "Confirm password: "
    read -rs password_confirm
    echo ""
    [[ "$password" != "$password_confirm" ]] && die "Passwords do not match."
  fi

  [[ ${#password} -lt 8 ]] && die "Password too short (minimum 8 characters)."

  info "Creating admin @${username}..."
  register_user "$username" "$password" "--admin"
  ok "Admin created: ${BOLD}@${username}:$(get_onion)${NC}  ‚Üí  http://$(get_onion):8448${NC}"
}

# =============================================================================
# COMMAND: user list
# =============================================================================
# Query the Synapse SQLite database directly to list all registered users.
# Displays username, role (admin / user), and account status (active / deactivated).
#
# Note: we use sqlite3 directly rather than the Synapse admin API to avoid
# needing a valid admin access token. This is simpler for a self-hosted setup.
# =============================================================================
cmd_user_list() {
  check_running
  section "Registered users"

  # Query the users table.
  # Columns: name, admin (1=yes), deactivated (1=yes), creation_ts (unix timestamp)
  # Results are ordered by creation date, newest first.
  local onion
  onion=$(get_onion)
  local base_url="http://${onion}:8448"

  docker exec "$SYNAPSE_CONTAINER" \
    python3 -c "
import sqlite3
con = sqlite3.connect('/data/homeserver.db')
rows = con.execute('SELECT name, admin, deactivated, datetime(creation_ts, \"unixepoch\") FROM users ORDER BY creation_ts DESC').fetchall()
base_url = '${base_url}'

col1, col2, col3, col4 = 'User', 'Role', 'Created', 'Homeserver URL'
w1 = max(len(col1), max((len(r[0]) for r in rows), default=0))
w2 = max(len(col2), 5)
w3 = max(len(col3), 19)
w4 = max(len(col4), len(base_url))

sep = f'  +-{\"-\"*w1}-+-{\"-\"*w2}-+-{\"-\"*w3}-+-{\"-\"*w4}-+'
print(sep)
print(f'  | {col1:<{w1}} | {col2:<{w2}} | {col3:<{w3}} | {col4:<{w4}} |')
print(sep)
for name, admin, deactivated, created in rows:
    role = 'admin' if admin else 'user'
    if deactivated:
        role += ' ‚úė'
    print(f'  | {name:<{w1}} | {role:<{w2}} | {created:<{w3}} | {base_url:<{w4}} |')
print(sep)
print(f'  {len(rows)} user(s)')
con.close()
" 2>/dev/null \
  || die "Could not read the Synapse database."

  echo ""
}

# =============================================================================
# COMMAND: user delete
# =============================================================================
# Deactivate a Matrix user account by setting the deactivated flag in the DB.
# The account data (messages, room memberships) is preserved ‚ÄĒ this is a soft
# deactivation, not a permanent deletion.
#
# Asks for confirmation before making any change.
# =============================================================================
cmd_user_delete() {
  check_running

  local username="${1:-}"
  [[ -z "$username" ]] && die "Usage: whistor user delete <username>"

  # Show a warning and ask for explicit confirmation before proceeding.
  warn "This will deactivate @${username}. Their data will be preserved."
  echo -n "Confirm? [y/N] "
  read -r confirm

  # Default to NO ‚ÄĒ only proceed if the user explicitly types y or Y.
  [[ "$confirm" != "y" && "$confirm" != "Y" ]] && { info "Cancelled."; exit 0; }

  # Set deactivated=1 for all users matching the username prefix.
  # We use LIKE '@username:%' to match the full Matrix ID format (@user:server).
  docker exec "$SYNAPSE_CONTAINER" \
    python3 -c "
import sqlite3
con = sqlite3.connect('/data/homeserver.db')
con.execute(\"UPDATE users SET deactivated=1 WHERE name LIKE '@${username}:%'\")
con.commit(); con.close()
" 2>/dev/null || die "Could not update the database."

  ok "@${username} has been deactivated."
}

# =============================================================================
# COMMAND: user passwd
# =============================================================================
# Change the password of an existing Matrix user account.
#
# The new password is hashed using Synapse's own password hashing function
# (bcrypt) and written directly to the database.
# =============================================================================
cmd_user_passwd() {
  check_running

  local username="${1:-}"
  [[ -z "$username" ]] && die "Usage: whistor user passwd <username>"

  # Prompt for the new password with confirmation.
  echo -n "New password for @${username}: "
  read -rs password
  echo ""
  echo -n "Confirm new password: "
  read -rs password_confirm
  echo ""

  [[ "$password" != "$password_confirm" ]] && die "Passwords do not match."
  [[ ${#password} -lt 8 ]] && die "Password too short (minimum 8 characters)."

  # Hash the password using Synapse's internal hashing function.
  # We run a small Python snippet inside the Synapse container to ensure
  # we use the exact same bcrypt parameters as Synapse itself.
  local hashed
  hashed=$(docker exec "$SYNAPSE_CONTAINER" \
    python3 -c "
from synapse.crypto.password_hash import hash_password
import asyncio
print(asyncio.run(hash_password('${password}')))
" 2>/dev/null) || die "Failed to hash the password. Is the Synapse container running?"

  # Write the new hash to the database.
  docker exec "$SYNAPSE_CONTAINER" \
    python3 -c "
import sqlite3
con = sqlite3.connect('/data/homeserver.db')
con.execute(\"UPDATE users SET password_hash='${hashed}' WHERE name LIKE '@${username}:%'\")
con.commit(); con.close()
" 2>/dev/null || die "Could not update the database."

  ok "Password updated for @${username}."
}

# =============================================================================
# MAIN ROUTER
# =============================================================================
# Read the first argument as the command name and dispatch to the appropriate
# function. Unknown commands print an error and exit with code 1.
# =============================================================================

# Read the command (default to "help" if no arguments were provided).
CMD="${1:-help}"

# Remove the command from the argument list so remaining args can be passed
# cleanly to the handler functions via "$@".
shift || true

case "$CMD" in
  start)          cmd_start ;;
  stop)           cmd_stop ;;
  restart)        cmd_restart ;;
  status)         cmd_status ;;
  logs)           cmd_logs "$@" ;;
  update)         cmd_update ;;
  onion)          cmd_onion ;;
  config)         cmd_config ;;
  backup)         cmd_backup ;;
  user)           cmd_user "$@" ;;
  help|--help|-h) cmd_help ;;
  *)
    die "Unknown command: '$CMD'. Run 'whistor help' for the list of available commands."
    ;;
esac
