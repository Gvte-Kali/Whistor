#!/bin/bash
# =============================================================================
# whistor — CLI management tool for the whistor Matrix/Tor server
# =============================================================================
#
# Usage:
#   whistor <command> [arguments]
#
# This script is installed into /usr/local/bin/whistor by install.sh.
# It wraps docker compose and docker exec calls behind a simple interface
# so you can manage the server and its users without remembering long commands.
#
# Available commands:
#   Server management : start, stop, restart, status, logs, update
#   Information       : onion, config
#   Data              : backup
#   User management   : user add, user admin, user list, user delete, user passwd
#
# =============================================================================

# Abort on error, treat unset variables as errors, propagate pipe failures.
set -euo pipefail

# =============================================================================
# CONFIGURATION
# =============================================================================

# Installation directory — can be overridden by setting WHISTOR_DIR.
# install.sh patches this default value to the actual installation path.
INSTALL_DIR="${WHISTOR_DIR:-$HOME/whistor}"

# Path to the Docker Compose file.
COMPOSE_FILE="${INSTALL_DIR}/docker-compose.yml"

# Docker container names — must match the container_name fields in compose.
SYNAPSE_CONTAINER="synapse-server"
TOR_CONTAINER="whistor-tor-daemon"

# Path to homeserver.yaml inside the Synapse container.
HOMESERVER_CONFIG="/data/homeserver.yaml"

# Synapse admin API base URL (only reachable from inside the Docker network
# or from the host via docker exec — never exposed externally).
HOMESERVER_URL="http://localhost:8008"

# =============================================================================
# TERMINAL COLORS AND LOGGING HELPERS
# =============================================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

ok()      { echo -e "${GREEN}✔${NC}  $*"; }
info()    { echo -e "${CYAN}→${NC}  $*"; }
warn()    { echo -e "${YELLOW}⚠${NC}  $*"; }
die()     { echo -e "${RED}✘  $*${NC}" >&2; exit 1; }
section() { echo -e "\n${BOLD}$*${NC}"; }

# =============================================================================
# HELPER: compose
# =============================================================================
# Thin wrapper around docker compose / docker-compose.
# Automatically passes -f to point at the correct compose file.
# Supports both the v2 CLI plugin (docker compose) and the legacy
# standalone binary (docker-compose).
# =============================================================================
compose() {
  if docker compose version &>/dev/null 2>&1; then
    # Docker Compose v2 — integrated CLI plugin.
    docker compose -f "$COMPOSE_FILE" "$@"
  else
    # Docker Compose v1 — legacy standalone binary.
    docker-compose -f "$COMPOSE_FILE" "$@"
  fi
}

# =============================================================================
# HELPER: check_running
# =============================================================================
# Verify that the Synapse container is currently running.
# Called at the start of any command that requires a live server.
# Exits with an error message if the container is stopped.
# =============================================================================
check_running() {
  docker inspect -f '{{.State.Running}}' "$SYNAPSE_CONTAINER" 2>/dev/null \
    | grep -q true \
    || die "Synapse container is not running. Start it with: whistor start"
}

# =============================================================================
# HELPER: get_onion
# =============================================================================
# Read the .onion hostname from inside the Tor container.
# Returns the address as a plain string, or "unavailable" on failure.
# =============================================================================
get_onion() {
  docker exec "$TOR_CONTAINER" \
    cat /var/lib/tor/hidden_service/hostname 2>/dev/null \
    | tr -d '[:space:]' \
    || echo "unavailable"
}

# =============================================================================
# HELPER: register_user
# =============================================================================
# Run the register_new_matrix_user tool inside the Synapse container.
# Arguments:
#   $1 — username
#   $2 — password
#   $3 — --admin or --no-admin
# =============================================================================
register_user() {
  local username="$1"
  local password="$2"
  local admin_flag="${3:---no-admin}"

  docker exec -i "$SYNAPSE_CONTAINER" \
    register_new_matrix_user \
      -c "$HOMESERVER_CONFIG" \
      -u "$username" \
      -p "$password" \
      "$admin_flag" \
      "$HOMESERVER_URL"
}

# =============================================================================
# COMMAND: help
# =============================================================================
# Print a formatted help screen with all available commands.
# Also shows the current .onion address for quick reference.
# =============================================================================
cmd_help() {
  # Try to get the .onion address for display in the header.
  # If the server is not running this will show "unavailable" — that is fine.
  local onion
  onion=$(get_onion 2>/dev/null || echo "unavailable")

  echo -e "${BOLD}${CYAN}"
  echo "  ██╗    ██╗██╗  ██╗██╗███████╗████████╗ ██████╗ ██████╗ "
  echo "  ██║    ██║██║  ██║██║██╔════╝╚══██╔══╝██╔═══██╗██╔══██╗"
  echo "  ██║ █╗ ██║███████║██║███████╗   ██║   ██║   ██║██████╔╝"
  echo "  ██║███╗██║██╔══██║██║╚════██║   ██║   ██║   ██║██╔══██╗"
  echo "  ╚███╔███╔╝██║  ██║██║███████║   ██║   ╚██████╔╝██║  ██║"
  echo "   ╚══╝╚══╝ ╚═╝  ╚═╝╚═╝╚══════╝   ╚═╝    ╚═════╝ ╚═╝  ╚═╝"
  echo -e "${NC}"
