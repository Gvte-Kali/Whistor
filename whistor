  echo ""

  echo -e "  ${BOLD}USERS${NC}"
  echo -e "  ${CYAN}whistor user add${NC} <user>              Create a user (interactive password)"
  echo -e "  ${CYAN}whistor user add${NC} <user> <password>   Create a user (inline password)"
